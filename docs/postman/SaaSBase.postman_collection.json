{
  "info": {
    "_postman_id": "saasbase-api-v1",
    "name": "SaaSBase API v1",
    "description": "SaaSBase HTTP API 集合。先执行登录，再调用需要认证的接口。",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "tenantCode", "value": "tenant-a" },
    { "key": "username", "value": "alice" },
    { "key": "password", "value": "pass123" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" },
    { "key": "operatorId", "value": "1" },
    { "key": "tenantId", "value": "1" },
    { "key": "userId", "value": "1" },
    { "key": "deptId", "value": "1" },
    { "key": "fileId", "value": "7" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "登录",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.success && json.data) {",
                  "  pm.collectionVariables.set('accessToken', json.data.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', json.data.refreshToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tenantCode\": \"{{tenantCode}}\",\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/login"
          }
        },
        {
          "name": "刷新 Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.success && json.data) {",
                  "  pm.collectionVariables.set('accessToken', json.data.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', json.data.refreshToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/refresh"
          }
        },
        {
          "name": "退出登录",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/logout"
          }
        }
      ]
    },
    {
      "name": "Tenant",
      "item": [
        {
          "name": "创建租户",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tenantCode\": \"tenant-b\",\n  \"tenantName\": \"租户 B\",\n  \"adminUsername\": \"admin\",\n  \"adminDisplayName\": \"管理员\",\n  \"initialPassword\": \"Secret123456\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/platform/tenants?operatorId={{operatorId}}"
          }
        },
        {
          "name": "租户列表",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/platform/tenants?tenantCode=&tenantName=&status=&pageNo=1&pageSize=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "platform", "tenants"],
              "query": [
                { "key": "tenantCode", "value": "" },
                { "key": "tenantName", "value": "" },
                { "key": "status", "value": "" },
                { "key": "pageNo", "value": "1" },
                { "key": "pageSize", "value": "20" }
              ]
            }
          }
        },
        {
          "name": "租户详情",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/v1/platform/tenants/{{tenantId}}"
          }
        },
        {
          "name": "更新租户",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tenantName\": \"租户 B（更新）\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/platform/tenants/{{tenantId}}?operatorId={{operatorId}}"
          }
        },
        {
          "name": "启用租户",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/v1/platform/tenants/{{tenantId}}/enable?operatorId={{operatorId}}"
          }
        },
        {
          "name": "停用租户",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/v1/platform/tenants/{{tenantId}}/disable?operatorId={{operatorId}}"
          }
        },
        {
          "name": "当前租户资料",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/v1/admin/tenant/profile"
          }
        }
      ]
    },
    {
      "name": "User",
      "item": [
        {
          "name": "创建用户",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"bob\",\n  \"initialPassword\": \"Secret123456\",\n  \"displayName\": \"Bob\",\n  \"phone\": \"13800000000\",\n  \"primaryDepartmentId\": 1,\n  \"roleIds\": [1]\n}"
            },
            "url": "{{baseUrl}}/api/v1/admin/users"
          }
        },
        {
          "name": "用户列表",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/admin/users?page=1&size=20&username=&departmentId=&status=&phone=",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "admin", "users"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "size", "value": "20" },
                { "key": "username", "value": "" },
                { "key": "departmentId", "value": "" },
                { "key": "status", "value": "" },
                { "key": "phone", "value": "" }
              ]
            }
          }
        },
        {
          "name": "用户详情",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/v1/admin/users/{{userId}}"
          }
        },
        {
          "name": "更新用户",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": 1,\n  \"displayName\": \"Bob Updated\",\n  \"phone\": \"13800000001\",\n  \"primaryDepartmentId\": 1,\n  \"roleIds\": [1],\n  \"version\": 1\n}"
            },
            "url": "{{baseUrl}}/api/v1/admin/users/{{userId}}"
          }
        },
        {
          "name": "启用用户",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/v1/admin/users/{{userId}}/enable?version=1"
          }
        },
        {
          "name": "停用用户",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/v1/admin/users/{{userId}}/disable?version=1"
          }
        },
        {
          "name": "重置密码",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": 1,\n  \"newPassword\": \"Secret123456\",\n  \"version\": 1\n}"
            },
            "url": "{{baseUrl}}/api/v1/admin/users/{{userId}}/reset-password"
          }
        },
        {
          "name": "调整部门",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"departmentId\": 2,\n  \"version\": 1\n}"
            },
            "url": "{{baseUrl}}/api/v1/admin/users/{{userId}}/transfer-dept"
          }
        }
      ]
    },
    {
      "name": "Department",
      "item": [
        {
          "name": "部门树",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/v1/admin/depts/tree"
          }
        },
        {
          "name": "部门详情",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/v1/admin/depts/{{deptId}}"
          }
        },
        {
          "name": "创建部门",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"parentId\": 0,\n  \"deptCode\": \"ops\",\n  \"deptName\": \"运营部\",\n  \"sortOrder\": 10\n}"
            },
            "url": "{{baseUrl}}/api/v1/admin/depts"
          }
        },
        {
          "name": "更新部门",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"deptName\": \"运营部（更新）\",\n  \"sortOrder\": 20,\n  \"version\": 1\n}"
            },
            "url": "{{baseUrl}}/api/v1/admin/depts/{{deptId}}"
          }
        },
        {
          "name": "移动部门",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"newParentId\": 0,\n  \"version\": 1\n}"
            },
            "url": "{{baseUrl}}/api/v1/admin/depts/{{deptId}}/move"
          }
        },
        {
          "name": "停用部门",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"version\": 1\n}"
            },
            "url": "{{baseUrl}}/api/v1/admin/depts/{{deptId}}/disable"
          }
        },
        {
          "name": "启用部门",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"version\": 1\n}"
            },
            "url": "{{baseUrl}}/api/v1/admin/depts/{{deptId}}/enable"
          }
        },
        {
          "name": "删除部门",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/v1/admin/depts/{{deptId}}?version=1"
          }
        },
        {
          "name": "部门成员",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/v1/admin/depts/{{deptId}}/members?descendants=false"
          }
        }
      ]
    },
    {
      "name": "File",
      "item": [
        {
          "name": "上传文件",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.success && json.data) {",
                  "  pm.collectionVariables.set('fileId', String(json.data.id));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": ""
                }
              ]
            },
            "url": "{{baseUrl}}/api/v1/admin/files"
          }
        },
        {
          "name": "文件列表",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/admin/files?filename=&contentType=&uploadedFrom=&uploadedTo=&pageNo=1&pageSize=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "admin", "files"],
              "query": [
                { "key": "filename", "value": "" },
                { "key": "contentType", "value": "" },
                { "key": "uploadedFrom", "value": "" },
                { "key": "uploadedTo", "value": "" },
                { "key": "pageNo", "value": "1" },
                { "key": "pageSize", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "文件详情",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/v1/admin/files/{{fileId}}"
          }
        },
        {
          "name": "文件内容",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/v1/admin/files/{{fileId}}/content?disposition=attachment"
          }
        },
        {
          "name": "删除文件",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/v1/admin/files/{{fileId}}"
          }
        }
      ]
    },
    {
      "name": "System",
      "item": [
        {
          "name": "健康检查",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/actuator/health"
          }
        },
        {
          "name": "OpenAPI 文档",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/v3/api-docs"
          }
        }
      ]
    }
  ]
}
